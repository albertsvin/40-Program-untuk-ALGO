#include <stdio.h>

int main() {
    char keperluan[50];
    float jumlah, batas, total = 0;
    int pilihan, i = 1;
    
    printf("================================\n");
    printf("   CATATAN PENGELUARAN HARIAN\n");
    printf("================================\n");
    
    // Input batas pengeluaran
    printf("Masukkan batas pengeluaran: Rp ");
    scanf("%f", &batas);
    printf("Batas Anda: Rp %.2f\n", batas);
    printf("================================\n");
    do {
        printf("\n--- Pengeluaran ke-%d ---\n", i);
        printf("Untuk keperluan apa? ");
        scanf("%s", keperluan);
        printf("Berapa jumlahnya? Rp ");
        scanf("%f", &jumlah);
        
        total = total + jumlah;
        
        printf("\n>> Total sementara: Rp %.2f", total);
        printf("\n>> Sisa batas: Rp %.2f", batas - total);
        
        if(total > batas) {
            printf("\n  PERINGATAN: Anda sudah MELEBIHI batas!");
            printf("\n  Kelebihan: Rp %.2f", total - batas);
        }
        
        printf("\n\nTambah lagi? (1=Ya, 0=Tidak): ");
        scanf("%d", &pilihan);
        
        i++;
        
    } while(pilihan == 1);
    printf("\n================================\n");
    printf("         RINGKASAN\n");
    printf("================================\n");
    printf("Total Pengeluaran: Rp %.2f\n", total);
    printf("Batas Pengeluaran: Rp %.2f\n", batas);
    printf("Sisa: Rp %.2f\n", batas - total);
    printf("================================\n");

    if(total > batas) {
        printf(" EVALUASI: Pengeluaran Anda MELEBIHI batas!\n");
        printf("             Coba hemat lagi bulan depan.\n");
    } else if(total == batas) {
        printf(" EVALUASI: Pengeluaran Anda PAS dengan batas.\n");
        printf("             Hati-hati jangan sampai kelebihan.\n");
    } else {
        printf(" EVALUASI: Pengeluaran Anda masih AMAN.\n");
        printf("             Sisa bisa ditabung.\n");
    }
    printf("================================\n");
    
    return 0;
}
