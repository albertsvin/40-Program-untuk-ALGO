
#include <stdio.h>
#include <string.h>

struct Menu {
    char nama[50];
    float harga;
};
struct Pegawai {
    char nama[50];
    char jabatan[30];
};
int main() {
    struct Menu daftarMenu[10] = {
        {"Nasi Goreng Spesial", 30000},
        {"Mie Goreng Seafood", 28000},
        {"Ayam Bakar Madu", 35000},
        {"Sate Ayam", 27000},
        {"Soto Betawi", 32000},
        {"Bakso Urat Jumbo", 25000},
        {"Ikan Bakar Rica-Rica", 40000},
        {"Nasi Uduk Komplit", 23000},
        {"Es Teh Manis", 8000},
        {"Jus Alpukat", 15000}
    };
    struct Pegawai daftarPegawai[5] = {
        {"Andi", "Manajer"},
        {"Budi", "Koki"},
        {"Citra", "Kasir"},
        {"Dewi", "Pelayan"},
        {"Eko", "Pelayan"}
    };

    int pilihan;
    do {
        printf("\n=== DATA RESTORAN ===\n");
        printf("1. Lihat Menu\n");
        printf("2. Lihat Pegawai\n");
        printf("3. Keluar\n");
        printf("Pilih: ");
        scanf("%d", &pilihan);
        switch (pilihan) {
            case 1:
                printf("\n--- DAFTAR MENU RESTORAN ---\n");
                for (int i = 0; i < 10; i++) {
                    printf("%2d. %-25s Rp%.0f\n", i + 1, daftarMenu[i].nama, daftarMenu[i].harga);
                }
                break;
            case 2:
                printf("\n--- DAFTAR PEGAWAI RESTORAN ---\n");
                for (int i = 0; i < 5; i++) {
                    printf("%d. %-10s | Jabatan: %s\n", i + 1, daftarPegawai[i].nama, daftarPegawai[i].jabatan);
                }
                break;

            case 3:
                printf("\nTerima kasih! Program selesai.\n");
                break;

            default:
                printf("\nPilihan tidak valid! Silakan coba lagi.\n");
        }
    } while (pilihan != 3);
    return 0;
}

