#include <stdio.h>

int main() {
    float berat, tinggi, bmi;
    
    printf("=== KALKULATOR BMI ===\n");
    printf("Masukkan berat badan (kg): ");
    scanf("%f", &berat);
    printf("Masukkan tinggi badan (cm): ");
    scanf("%f", &tinggi);
    tinggi = tinggi / 100;

    bmi = berat / (tinggi * tinggi);
    
    printf("\nBMI Anda: %.2f\n", bmi);
    printf("Kategori: ");
    if(bmi < 18.5)
        printf("Kurus (Underweight)\n");
    else if(bmi < 25)
        printf("Normal (Ideal)\n");
    else if(bmi < 30)
        printf("Gemuk (Overweight)\n");
    else
        printf("Obesitas\n");
    return 0;
}
