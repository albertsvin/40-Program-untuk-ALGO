#include <stdio.h>

int main() {
    int n = 5;
    int i, j, nilai;
    for (i = 0; i < n; i++) {
        nilai = 1;
        for (j = 0; j < n - i - 1; j++) {
            printf(" ");
        }
        for (j = 0; j <= i; j++) {
            printf("%d ", nilai);
            nilai = nilai * (i - j) / (j + 1); 
        } printf("\n");
    }
    return 0;
}
