#include <stdio.h>
#include <string.h>

int main() {
    char kata[100];

    printf("Masukkan sebuah kata (tanpa spasi): ");
    scanf("%s", kata);
    printf("Kata setelah dibalik: ");
    for (int i = strlen(kata) - 1; i >= 0; i--) {
        printf("%c", kata[i]);
    }
    printf("\n");

    return 0;
}
