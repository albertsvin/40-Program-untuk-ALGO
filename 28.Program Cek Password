#include <stdio.h>
#include <string.h>

int main() {
    char password[50];
    int ada_besar = 0, ada_kecil = 0, ada_angka = 0;

printf(" CYBER SECURITY: PASSWORD CHECKER \n");
    
    printf("Masukkan password kamu: ");
    scanf("%s", password);

    printf("\nMemindai keamanan password...\n");
    if (strlen(password) < 8) {
        printf("STATUS: SANGAT LEMAH\n");
        printf("Alasan: Password kurang dari 8 karakter!\n");
        return 0; 
    }

    for (int i = 0; i < strlen(password); i++) {
        if (password[i] >= 'A' && password[i] <= 'Z') {
            ada_besar = 1;
        }
        else if (password[i] >= 'a' && password[i] <= 'z') {
            ada_kecil = 1;
        }
        else if (password[i] >= '0' && password[i] <= '9') {
            ada_angka = 1;
        }
        
    }
    if (ada_besar == 1 && ada_kecil == 1 && ada_angka == 1) {
        printf("STATUS: SANGAT KUAT\n");
        printf("Password sudah aman\n");
    } else {
        printf("STATUS: SEDANG / LEMAH\n");
        printf("Saran perbaikan:\n");
        if (ada_besar == 0) printf("- Tambahkan minimal 1 Huruf KAPITAL\n");
        if (ada_kecil == 0) printf("- Tambahkan minimal 1 Huruf kecil\n");
        if (ada_angka == 0) printf("- Tambahkan minimal 1 Angka\n");
    }
    return 0;
}
